{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tias",
  "version": "0.1.0",
  "identifier": "com.tias.app",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tias",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
